#include "resource.h"
#include <afxres.h>

LANGUAGE LANG_CHINESE, SUBLANG_CHINESE_SIMPLIFIED

IDD_IMAGE_MATCHING_DIALOG DIALOGEX 0, 0, 1100, 760
STYLE DS_SETFONT | DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU | WS_THICKFRAME | WS_MINIMIZEBOX | WS_MAXIMIZEBOX
EXSTYLE WS_EX_APPWINDOW
CAPTION "Image Matching"
FONT 9, "Microsoft YaHei UI", 0, 0, 0x0
BEGIN
    PUSHBUTTON      "Load Src",IDC_BUTTON_LOAD_SRC,8,8,84,24
    PUSHBUTTON      "Load Target",IDC_BUTTON_LOAD_TARGET,100,8,92,24
    PUSHBUTTON      "PHASE",IDC_BUTTON_METHOD_PHASE,200,8,74,24
    PUSHBUTTON      "ORB",IDC_BUTTON_METHOD_ORB,282,8,74,24
    PUSHBUTTON      "AKAZE",IDC_BUTTON_METHOD_AKAZE,364,8,74,24
    PUSHBUTTON      "SIFT",IDC_BUTTON_METHOD_SIFT,446,8,74,24
    PUSHBUTTON      "ECC",IDC_BUTTON_METHOD_ECC,528,8,74,24
    PUSHBUTTON      "Reset View",IDC_BUTTON_RESET,610,8,92,24
    EDITTEXT        IDC_EDIT_RESULT,8,40,1084,72,ES_MULTILINE | ES_AUTOVSCROLL | ES_READONLY | WS_VSCROLL
END
